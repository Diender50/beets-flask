# following this reference suggesting to exclude everything, and only
# manually include whats needed
# https://markbirbeck.com/2018/12/07/getting-control-of-your-dockerignore-files/

# Let's taylor the docker ignore only for the production image, there is no real
# need to push the dev image to the registry

*

# Explicitly exclude transient folders first so Docker sender does not try to
# read locked files on Windows while traversing directories.
frontend/node_modules
frontend/node_modules/**
frontend/.pnpm-store
frontend/.pnpm-store/**
frontend/dist
frontend/dist/**
backend/.venv
backend/.venv/**
backend/.pytest_cache
backend/.pytest_cache/**
backend/.mypy_cache
backend/.mypy_cache/**

# Ignore all frontend children by default, then include only build inputs.
frontend/*

!backend/beets_flask
!backend/pyproject.toml
!backend/main.py
!backend/launch_*.py
!backend/generate_types.py

!configs/

!frontend/src/
!frontend/public/

!frontend/.eslintrc.js
!frontend/eslint.config.js
!frontend/index.html
!frontend/package.json
!frontend/pnpm-lock.yaml
!frontend/prettier.config.js
!frontend/postcss.config.js
!frontend/tailwind.config.js
!frontend/tsconfig.json
!frontend/vite.config.ts

!README.md
!LICENSE
!docker/entrypoints/entrypoint*.sh
!docker/entrypoints/common.sh
